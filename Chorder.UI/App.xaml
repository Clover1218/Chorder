<Application x:Class="Chorder.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Chorder.UI" xmlns:System="clr-namespace:System;assembly=netstandard" xmlns:cvt="clr-namespace:Chorder.UI.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ========== 我 ========== -->
        <SolidColorBrush x:Key="Brush_Bg" Color="#F8F9FA"/>
        <!-- 整体背景 -->
        <SolidColorBrush x:Key="Brush_Surface" Color="#FFFFFF"/>
        <!-- 卡片/列表背景 -->
        <SolidColorBrush x:Key="Brush_Border" Color="#111111"/>
        <!-- 粗黑边框 -->
        <SolidColorBrush x:Key="Brush_Text" Color="#111111"/>
        <SolidColorBrush x:Key="Brush_Black" Color="#111111"/>
        <!-- 主要文字 -->
        <SolidColorBrush x:Key="Brush_TextLight" Color="#555555"/>
        <!-- 次要文字 -->
        <SolidColorBrush x:Key="Brush_Red" Color="#FF6B6B"/>
        <!-- 淡红 -->
        <SolidColorBrush x:Key="Brush_Yellow" Color="#FFD93D"/>
        <!-- 淡黄 -->
        <SolidColorBrush x:Key="Brush_Red_Hover" Color="#FF5252"/>
        <!-- 红悬停 -->
        <SolidColorBrush x:Key="Brush_Yellow_Hover" Color="#FFC107"/>

        <SolidColorBrush x:Key="Brush_White" Color="#FFFFFF"/>
        <!-- 黄悬停 -->

        <!-- ========== 全局字体 ========== -->
        <FontFamily x:Key="Font_Bold">Segoe UI</FontFamily>
        <FontFamily x:Key="Font_Regular">Segoe UI</FontFamily>
        <System:Double x:Key="FontSize_Normal">13</System:Double>

        <!-- ========== 按钮样式（新粗野风格） ========== -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe UI, Microsoft YaHei"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!-- 关键：垂直居中 -->
            <Setter Property="Background" Value="{StaticResource Brush_Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <!-- 关键：这里绑定 HorizontalContentAlignment 和 VerticalContentAlignment -->
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Red}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Red_Hover}"/>
                                <Setter Property="Margin" Value="1,1,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 黄色强调按钮（用于重要操作，如“新建歌单”） -->
        <Style x:Key="Button_Yellow" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Brush_Yellow}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Yellow_Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 红色危险按钮（删除） -->
        <Style x:Key="Button_Danger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Brush_Red}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Red_Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ========== 文本框样式 ========== -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Brush_Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Brush_Text}"/>
        </Style>

        <!-- ========== ListBox 及 ListBoxItem ========== -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource Brush_Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="{StaticResource FontSize_Normal}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush_Text}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Red}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Brush_Yellow}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Border / 卡片效果 ========== -->
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource Brush_Border}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource Brush_Surface}"/>
        </Style>

        <!-- ========== 分隔线 ========== -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Brush_Border}"/>
            <Setter Property="Height" Value="2"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- ========== 转换器等 ========== -->
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"/>

    </Application.Resources>
</Application>