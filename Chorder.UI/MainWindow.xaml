<Window x:Class="Chorder.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" xmlns:local="clr-namespace:Chorder.UI.Behaviors"
        xmlns:ctrl="clr-namespace:Chorder.UI.Controls"
        xmlns:cvt="clr-namespace:Chorder.UI.Converters"
        Title="Chorder" Height="450" Width="800">
    <Window.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0"
                     Margin="5"
                     Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Row="1"
                    Margin="5"
                    Content="Search"
                    Command="{Binding SearchCommand}" />

            <TreeView Grid.Row="2"
                      Margin="5"
                      ItemsSource="{Binding SearchItems}"
                      SelectedItemChanged="TreeView_SelectedItemChanged">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <EventSetter Event="MouseDoubleClick"
                                     Handler="TreeViewItem_MouseDoubleClick"/>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" Width="250"/>
                            <Button Content="+"
                                    Margin="5,0"
                                    Command="{Binding DataContext.AddToPlaybackQueueCommand, 
                                             RelativeSource={RelativeSource AncestorType=TreeView}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="▶"
                                    Margin="5,0"
                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                    CommandParameter="{Binding}" />
                            <Button Content="📂"
                                    Margin="5,0"
                                    Command="{Binding DataContext.AddToPlaylistCommand,
                                    RelativeSource={RelativeSource AncestorType=TreeView}}"
                                    CommandParameter="{Binding}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        <Border Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <!-- 歌单列表 -->
                    <ColumnDefinition Width="2*"/>
                    <!-- 歌单内容 -->
                </Grid.ColumnDefinitions>

                <!-- 左：歌单列表 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 新建歌单 -->
                    <Button Content="＋ 新建歌单"
                    Margin="5"
                    Command="{Binding CreatePlaylistCommand}"/>

                    <!-- 歌单列表 -->
                    <ListBox Grid.Row="1"
                     Margin="5"
                     ItemsSource="{Binding Playlists}"
                     SelectedItem="{Binding SelectedPlaylist}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="PreviewMouseLeftButtonDown"
                                             Handler="PlaylistLibarayItem_PreviewMouseLeftButtonDown"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="24">

                                    <TextBlock Text="{Binding Name}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 编辑 -->
                                    <ctrl:InlineEditTextBox
                                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        IsEditing="{Binding IsEditing}"
                                        CommitCommand="{Binding DataContext.EndEditPlaylistCommand,
                                                        RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommitCommandParameter="{Binding}">
                                        <ctrl:InlineEditTextBox.Style>
                                            <Style TargetType="ctrl:InlineEditTextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ctrl:InlineEditTextBox.Style>
                                    </ctrl:InlineEditTextBox>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- 右：歌单内容 -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock Text="{Binding SelectedPlaylist.Name}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5"/>

                    <!-- 歌曲列表 -->
                    <ListBox Grid.Row="1"
                     Margin="5"
                     ItemsSource="{Binding SelectedPlaylistTracks}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" Width="150"/>

                                    <!-- 播放 -->
                                    <Button Content="▶"
                                    Margin="5,0"
                                    Command="{Binding DataContext.PlayTrackCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />

                                    <!-- 加入播放队列 -->
                                    <Button Content="+"
                                    Margin="5,0"
                                    Command="{Binding DataContext.AddTrackToQueueCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />


                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Column="2" Margin="5" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="播放队列"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5"/>

                <ListBox Grid.Row="1"
                         Margin="5"
                         ItemsSource="{Binding PlaybackQueue}">
                    <i:Interaction.Behaviors>
                        <local:ListBoxDragDropBehavior/>
                    </i:Interaction.Behaviors>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="AllowDrop" Value="True"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Background" Value="LightGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" Width="150"/>


                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <Border Background="#80000000"
        Visibility="{Binding IsPlaylistPopupOpen, Converter={StaticResource BoolToVis}}"
        MouseDown="ClosePopup"/>

        <!-- Popup Widget -->
        <Border Width="250"
        Background="White"
        CornerRadius="8"
        Padding="10"
        Visibility="{Binding IsPlaylistPopupOpen, Converter={StaticResource BoolToVis}}"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="选择歌单"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                <ListBox ItemsSource="{Binding PlaylistPicker.Playlists}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                            Command="{Binding DataContext.PlaylistPicker.AddToPlaylistCommand,
                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </Border>
    </Grid>
</Window>
