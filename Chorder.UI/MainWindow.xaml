<Window x:Class="Chorder.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:Chorder.UI.Behaviors"
        xmlns:vm="clr-namespace:Chorder.UI.ViewModels"
        xmlns:ctrl="clr-namespace:Chorder.UI.Controls"
        xmlns:stat="clr-namespace:Chorder.UI.Views.Statistics"
        xmlns:cvt="clr-namespace:Chorder.UI.Converters"
        xmlns:views="clr-namespace:Chorder.UI.Views"
        Title="Chorder" Height="600" Width="800">
    <Window.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <cvt:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <cvt:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="CHORDER"
                           FontSize="20"
                           Margin="12,8"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,8,4">
                    <Button Content="当前播放"
                            Command="{Binding SwitchToNowPlayingCommand}"/>
                    <Button Content="歌单"
                            Command="{Binding SwitchToPlaylistCommand}"/>
                    <Button Content="播放列表"
                            Command="{Binding SwitchToCurrentPlayCommand}"/>
                    <Button Content="搜索"
                            Command="{Binding SwitchToSearchCommand}"/>
                    <Button Content="统计"
                            Command="{Binding SwitchToStatisticsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 搜索视图 ========== -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Search">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Margin="8"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="1" Margin="8,4"
                        Content="SEARCH"
                        Command="{Binding SearchCommand}"/>

                <TreeView Grid.Row="2" Margin="8"
                          ItemsSource="{Binding SearchItems}"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="+"
                                            Command="{Binding DataContext.AddToPlaybackQueueCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="▶"
                                            Command="{Binding DataContext.PlayFromSearchCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="📂"
                                            Command="{Binding DataContext.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- ========== 歌单视图 ========== -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Playlist">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：歌单列表 -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Content="＋ 新建歌单" Margin="6"
                                Command="{Binding CreatePlaylistCommand}"/>

                        <ListBox Grid.Row="1" Margin="6"
                                 ItemsSource="{Binding Playlists}"
                                 SelectedItem="{Binding SelectedPlaylist}">
                            <i:Interaction.Behaviors>
                                <local:ListBoxDragDropBehavior/>
                            </i:Interaction.Behaviors>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="AllowDrop" Value="True"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- 右：歌单内容 -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Margin="6,6,6,4" Padding="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SelectedPlaylist.Name}"
                                           FontSize="20" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="✏" Margin="0,0,8,0" FontSize="14"
                                        Command="{Binding OpenRenamePlaylistCommand}"
                                        CommandParameter="{Binding SelectedPlaylist}"/>
                                <Button Grid.Column="3" Content="✕" FontSize="14"
                                        Command="{Binding DeletePlaylistCommand}"
                                        CommandParameter="{Binding SelectedPlaylist}"/>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1" Margin="6"
                                 ItemsSource="{Binding SelectedPlaylistTracks}">
                            <i:Interaction.Behaviors>
                                <local:ListBoxDragDropBehavior/>
                            </i:Interaction.Behaviors>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="AllowDrop" Value="True"/>
                                    <Setter Property="MinHeight" Value="32"/>
                                    <Setter Property="Padding" Value="4,4"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="✏"
                                                    Command="{Binding DataContext.OpenRenamePlaylistTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="▶"
                                                    Command="{Binding DataContext.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="+"
                                                    Command="{Binding DataContext.AddTrackToQueueCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="📂"
                                                    Command="{Binding DataContext.AddPlaylistTrackToPlaylistCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="✕"
                                                    Command="{Binding DataContext.RemoveSelectedPlaylistTrackCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- ========== 当前播放视图 ========== -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="8" Padding="16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="NowPlaying">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover -->
                    <Border Width="200" Height="200"
                            BorderBrush="Gray" BorderThickness="1"
                            HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image Source="{Binding NowPlayingCoverPath}" Stretch="UniformToFill"/>
                    </Border>

                    <!-- 歌曲信息 -->
                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding NowPlayingTitle}" FontSize="28" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding NowPlayingAuthor}" FontSize="18" Margin="0,8,0,0"
                                   Foreground="Gray"/>
                        <Separator Margin="0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="原标题" Foreground="Gray" Margin="0,0,16,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NowPlayingOriginalTitle}" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="BV号" Foreground="Gray" Margin="0,0,16,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NowPlayingBvid}" Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="分P" Foreground="Gray" Margin="0,0,16,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NowPlayingPage}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="缓存"
                                    Command="{Binding DownloadCacheCommand}"
                                    IsEnabled="{Binding NowPlayingIsDownloading, Converter={StaticResource InvertBoolConverter}}"
                                    Margin="0,0,8,0" Padding="12,6"/>
                            <Button Content="删除缓存"
                                    Command="{Binding DeleteCacheCommand}"
                                    Margin="0,0,8,0" Padding="12,6"/>
                            <TextBlock Text="下载中..."
                                       Visibility="{Binding NowPlayingIsDownloading, Converter={StaticResource BoolToVis}}"
                                       Foreground="Gray" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========== 播放队列视图 ========== -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="CurrentPlay">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Margin="8,8,8,4" Padding="0,0,0,6">
                        <TextBlock Text="播放队列" FontSize="20"/>
                    </Border>

                    <ListBox Grid.Row="1" Margin="8"
                             ItemsSource="{Binding PlaybackQueue}">
                        <i:Interaction.Behaviors>
                            <local:ListBoxDragDropBehavior/>
                        </i:Interaction.Behaviors>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <Setter Property="MinHeight" Value="32"/>
                                <Setter Property="Padding" Value="4,4"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayTitle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="✏"
                                                Command="{Binding DataContext.OpenRenamePlaybackItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="▶"
                                                Command="{Binding DataContext.PlayFromPlaybackQueueCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="📂"
                                                Command="{Binding DataContext.AddPlaybackItemToPlaylistCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="✕"
                                                Command="{Binding DataContext.RemovePlaybackQueueItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ========== 播放数据统计视图 ========== -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentView}" Value="Statistics">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                        <Button Content="◀ 上一页"
                                Command="{Binding StatisticsViewModel.PreviousPageCommand}"
                                Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding StatisticsViewModel.CurrentPage?.Title}"
                                   FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Content="下一页 ▶"
                                Command="{Binding StatisticsViewModel.NextPageCommand}"
                                Margin="16,0,0,0"/>
                    </StackPanel>

                    <ContentControl Grid.Row="1" Margin="8" Content="{Binding StatisticsViewModel.CurrentPage}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:TopPlayedPage}">
                                <stat:TopPlayedPageView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayHistoryPage}">
                                <stat:PlayHistoryPageView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:SummaryPage}">
                                <stat:SummaryPageView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Grid>
            </Border>

            <!-- ========== 歌单选择弹出框 ========== -->
        </Grid>

        <!-- ========== 歌单选择弹出框（全屏覆盖） ========== -->
        <Border Grid.RowSpan="3" Background="#80000000"
                Visibility="{Binding IsPlaylistPopupOpen, Converter={StaticResource BoolToVis}}"
                MouseDown="ClosePopup"/>
        <Border Grid.RowSpan="3" Width="280" Padding="14"
                Visibility="{Binding IsPlaylistPopupOpen, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="选择歌单" FontSize="18" Margin="0,0,0,12"/>
                <ListBox ItemsSource="{Binding PlaylistPicker.Playlists}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Command="{Binding DataContext.PlaylistPicker.AddToPlaylistCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- ========== 重命名弹出框（全屏覆盖） ========== -->
        <Border Grid.RowSpan="3" Background="#80000000"
                Visibility="{Binding IsRenamePopupOpen, Converter={StaticResource BoolToVis}}"/>
        <Border Grid.RowSpan="3" Width="300" Padding="16"
                Visibility="{Binding IsRenamePopupOpen, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="重命名" FontSize="18" Margin="0,0,0,12"/>
                <TextBox Text="{Binding RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="确定" Margin="0,0,8,0"
                            Command="{Binding ConfirmRenameCommand}"/>
                    <Button Content="取消"
                            Command="{Binding CancelRenameCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <views:PlayerBar Grid.Row="2" DataContext="{Binding PlayerDataContext}"/>
    </Grid>
</Window>