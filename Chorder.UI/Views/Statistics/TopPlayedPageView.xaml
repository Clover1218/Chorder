<UserControl x:Class="Chorder.UI.Views.Statistics.TopPlayedPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cvt="clr-namespace:Chorder.UI.Converters">

    <UserControl.Resources>
        <cvt:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#FFD700"/>
        <SolidColorBrush x:Key="SilverBrush" Color="#C0C0C0"/>
        <SolidColorBrush x:Key="BronzeBrush" Color="#CD7F32"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#B8860B"/>
        <SolidColorBrush x:Key="SilverDarkBrush" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="BronzeDarkBrush" Color="#8B4513"/>
    </UserControl.Resources>

    <Grid Height="350" Width="548">
        <!-- 底部对齐的领奖台 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,0">

            <!-- 第2名 - 银牌 -->
            <Grid Margin="8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- 封面、名称、时长 - 在领奖台上方 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,92,0,8" Grid.RowSpan="3">
                    <TextBlock Text="🥈 2" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource SilverBrush}" HorizontalAlignment="Center"/>
                    <Border Width="70" Height="70" CornerRadius="6" Margin="0,8,0,0"
                                BorderBrush="{StaticResource SilverDarkBrush}" BorderThickness="2">
                        <Grid>
                            <Image Source="{Binding SecondPlace.CoverPath}" Stretch="UniformToFill"/>
                            <TextBlock Text="暂无" Foreground="Gray" FontSize="9"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding SecondPlace.CoverPath, ConverterParameter=inverse, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding SecondPlace.Name}" FontSize="11" FontWeight="Bold"
                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="90" Margin="0,6,0,2"/>
                    <TextBlock Text="{Binding SecondPlace.PlayedTimeFormatted}"
                                   FontSize="10" Foreground="Gray" TextAlignment="Center"/>
                </StackPanel>

                <!-- 领奖台柱子 - 顶部紧贴下方内容 -->
                <Border Grid.Row="2" Width="100" Height="100"
                            Background="{StaticResource SilverBrush}"
                            CornerRadius="0,0,8,8"
                            BorderBrush="{StaticResource SilverDarkBrush}"
                            BorderThickness="2,2,2,2" Margin="0,250,0,-117"/>
            </Grid>

            <!-- 第1名 - 金牌 (最高) -->
            <Grid Margin="8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="130"/>
                </Grid.RowDefinitions>

                <!-- 封面、名称、时长 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,39,0,221" Grid.RowSpan="3">
                    <TextBlock Text="🏆 1" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource GoldDarkBrush}" HorizontalAlignment="Center"/>
                    <Border Width="90" Height="90" CornerRadius="8" Margin="0,8,0,0"
                                BorderBrush="{StaticResource GoldDarkBrush}" BorderThickness="3">
                        <Grid>
                            <Image Source="{Binding FirstPlace.CoverPath}" Stretch="UniformToFill"/>
                            <TextBlock Text="暂无" Foreground="Gray" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding FirstPlace.CoverPath, ConverterParameter=inverse, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding FirstPlace.Name}" FontSize="13" FontWeight="Bold"
                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="110" Margin="0,8,0,2"/>
                    <TextBlock Text="{Binding FirstPlace.PlayedTimeFormatted}"
                                   FontSize="11" Foreground="Gray" TextAlignment="Center"/>
                </StackPanel>

                <!-- 领奖台柱子 -->
                <Border Grid.Row="1" Width="120" Height="130"
                            Background="{StaticResource GoldBrush}"
                            CornerRadius="0,0,8,8"
                            BorderBrush="{StaticResource GoldDarkBrush}"
                            BorderThickness="2,2,2,2" Margin="0,219,0,72" Grid.RowSpan="2"/>
            </Grid>

            <!-- 第3名 - 铜牌 -->
            <Grid Margin="8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- 封面、名称、时长 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,135,0,-57" Grid.RowSpan="3">
                    <TextBlock Text="🥉 3" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BronzeBrush}" HorizontalAlignment="Center"/>
                    <Border Width="60" Height="60" CornerRadius="4" Margin="0,8,0,0"
                                BorderBrush="{StaticResource BronzeDarkBrush}" BorderThickness="2">
                        <Grid>
                            <Image Source="{Binding ThirdPlace.CoverPath}" Stretch="UniformToFill"/>
                            <TextBlock Text="暂无" Foreground="Gray" FontSize="8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding ThirdPlace.CoverPath, ConverterParameter=inverse, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding ThirdPlace.Name}" FontSize="10" FontWeight="Bold"
                                   TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="80" Margin="0,5,0,2"/>
                    <TextBlock Text="{Binding ThirdPlace.PlayedTimeFormatted}"
                                   FontSize="9" Foreground="Gray" TextAlignment="Center"/>
                </StackPanel>

                <!-- 领奖台柱子 -->
                <Border Grid.Row="2" Width="90" Height="80"
                            Background="{StaticResource BronzeBrush}"
                            CornerRadius="0,0,8,8"
                            BorderBrush="{StaticResource BronzeDarkBrush}"
                            BorderThickness="2,2,2,2" Margin="0,270,0,-152"/>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>